<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Neon Hockey Online - Room Match</title>
    <style>
        body { margin: 0; background: #000; color: #fff; font-family: 'Arial Black', sans-serif; overflow: hidden; touch-action: none; }
        canvas { display: block; }
        #menu { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.9); display: flex; flex-direction: column; align-items: center; justify-content: center; z-index: 100; }
        .settings { background: #111; padding: 20px; border-radius: 15px; border: 1px solid #333; margin-bottom: 20px; text-align: center; }
        .neon-btn { padding: 15px 40px; font-size: 20px; background: #00ff88; color: #000; border: none; border-radius: 50px; cursor: pointer; font-weight: bold; }
        #status { position: fixed; top: 10px; width: 100%; text-align: center; color: #00ff88; font-size: 18px; z-index: 10; }
        .host-only { display: none; } /* 1P以外には隠す */
    </style>
</head>
<body>

<div id="status">サーバー接続中...</div>

<div id="menu">
    <h1 id="room-title">WAITING FOR PLAYER...</h1>
    <div class="settings">
        <div id="host-controls" class="host-only">
            <p>【あなたはホストです】</p>
            <label><input type="checkbox" id="enableItems" checked> アイテム出現</label><br>
            <label><input type="checkbox" id="enableSkills" checked> スキル有効</label><br>
            <button class="neon-btn" style="margin-top:15px" onclick="pressStart()">対戦開始</button>
        </div>
        <div id="guest-msg">ホストが設定を変更中...</div>
    </div>
</div>

<canvas id="game"></canvas>

<script src="/socket.io/socket.io.js"></script>
<script>
    const socket = io();
    const canvas = document.getElementById('game');
    const ctx = canvas.getContext('2d');
    
    let w, h, mySide = null;
    let gameActive = false;
    let config = { items: true, skills: true };
    let ball = { x: 0, y: 0, vx: 6, vy: 6, r: 15 };
    let p1 = { x: 80, y: 0, r: 40, color: '#ff0055' };
    let p2 = { x: 0, y: 0, r: 40, color: '#00ccff' };

    socket.on('init', (data) => {
        mySide = data.side;
        config = data.config;
        document.getElementById('status').innerText = `YOU ARE ${mySide.toUpperCase()}`;
        if (mySide === 'left') {
            document.getElementById('host-controls').style.display = 'block';
            document.getElementById('guest-msg').style.display = 'none';
            document.getElementById('room-title').innerText = "HOST MODE";
        }
    });

    socket.on('config_update', (newConfig) => {
        config = newConfig;
        // ゲスト側のチェックボックス等も同期させるならここに書く
    });

    function pressStart() {
        if (mySide !== 'left') return;
        const finalConfig = {
            items: document.getElementById('enableItems').checked,
            skills: document.getElementById('enableSkills').checked
        };
        socket.emit('config_change', finalConfig);
        startGame();
    }

    socket.on('update', (data) => {
        if (data.side === 'left') { p1.x = data.x * w; p1.y = data.y * h; }
        if (data.side === 'right') { p2.x = data.x * w; p2.y = data.y * h; }
    });

    socket.on('ball_update', (data) => {
        if (mySide !== 'left') { ball.x = data.x * w; ball.y = data.y * h; }
    });

    function startGame() {
        document.getElementById('menu').style.display = 'none';
        gameActive = true;
        init();
        loop();
    }

    // --- 以降、描画・物理ロジック（前回のコードをベースに同期処理を組み込み） ---
    function init() {
        w = canvas.width = window.innerWidth;
        h = canvas.height = window.innerHeight;
        p1.y = p2.y = h/2; p2.x = w-80;
        ball.x = w/2; ball.y = h/2;
    }

    canvas.addEventListener('pointermove', (e) => {
        if (!gameActive || mySide === 'spectator') return;
        let tx = e.clientX, ty = e.clientY;
        if (mySide === 'left' && tx < w/2) {
            p1.x = tx; p1.y = ty;
            socket.emit('move', { x: p1.x/w, y: p1.y/h });
        } else if (mySide === 'right' && tx > w/2) {
            p2.x = tx; p2.y = ty;
            socket.emit('move', { x: p2.x/w, y: p2.y/h });
        }
    });

    function loop() {
        if (!gameActive) return;
        ctx.fillStyle = '#000'; ctx.fillRect(0,0,w,h);

        if (mySide === 'left') {
            ball.x += ball.vx; ball.y += ball.vy;
            if (ball.y < ball.r || ball.y > h-ball.r) ball.vy *= -1;
            [p1, p2].forEach(p => {
                if (Math.hypot(ball.x - p.x, ball.y - p.y) < ball.r + p.r) {
                    ball.vx = (ball.x - p.x) * 0.2; ball.vy = (ball.y - p.y) * 0.2;
                }
            });
            if (ball.x < 0 || ball.x > w) { ball.x = w/2; ball.y = h/2; ball.vx = 6; ball.vy = 6; }
            socket.emit('ball_sync', { x: ball.x/w, y: ball.y/h });
        }

        [p1, p2].forEach(p => {
            ctx.fillStyle = p.color; ctx.beginPath(); ctx.arc(p.x, p.y, p.r, 0, Math.PI*2); ctx.fill();
        });
        ctx.fillStyle = '#fff'; ctx.beginPath(); ctx.arc(ball.x, ball.y, ball.r, 0, Math.PI*2); ctx.fill();
        
        requestAnimationFrame(loop);
    }

    window.onresize = init;
    init();
</script>
</body>
</html>
